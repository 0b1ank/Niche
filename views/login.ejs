<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Niche Cafes - Login</title>
    <link rel="stylesheet" href="login.css">
    <link rel="stylesheet" href="style.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-header"></div>
        <ul class="nav-links">
            <li><a href="/" class="active"><i class='bx bx-home-alt-2'></i> <span>Home</span></a></li>
            <li><a href="#"><i class="bx bx-book-add"></i> <span>Add</span></a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="login-header">
            <h2>Welcome Back</h2>
            <p>Log in to access your saved Niche Cafes</p>
        </div>

        <% if (typeof error !== "undefined" && error) { %>
            <p style="color: red; text-align: center;"><%= error %></p>
        <% } %>

        <%# email + password login, handled by passport on the server %>
        <form action="/login" method="POST" id="loginForm">
            <div class="input-group">
                <label for="email">Email</label>
                <div class="input-wrapper">
                    <i class='bx bx-user'></i>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required>
                </div>
            </div>

            <div class="input-group">
                <label for="password">Password</label>
                <div class="input-wrapper">
                    <i class='bx bx-lock-alt'></i>
                    <input type="password" id="password" name="password" placeholder="Enter your password" required>
                </div>
            </div>

            <button type="submit" class="submit-btn">Sign In</button>
        </form>

        <div class="divider">or</div>

        <%# or sign in with google instead %>
        <div class="auth-links" style="text-align: center;">
            <p><a href="/auth/google">Continue with Google</a></p>
            <br>
            <a href="/register" class="create-account-btn">Need an account? Register</a>
        </div>
    </main>
</body>
</html>
