<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Community Feed</title>

        <link rel="stylesheet" href="style.css">
        <link rel="stylesheet" href="feedStyle.css">

    </head>
    <body>

        <!--Sidebar-->
        <%# nav links for the community feed section %>
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Niche - Cafe Share</h2>
            </div>

            <ul class="nav-links">
                <li><a href="/" class="active"><i class="fa-solid fa-mug-hot"></i> <span>Cafes</span></a></li>
                <li><a href="/posts" class="active"><i class="fa-solid fa-images"></i> <span>Community</span></a></li>
                <li><a href="/create-post"><i class="fa-solid fa-plus"></i> <span>Create</span></a></li>
                <li><a href="/profile"><i class="fa-solid fa-user"></i> <span>Profile</span></a></li>
            </ul>

            <div class="sidebar-footer">
                <a href="/logout"><i class="fa-solid fa-right-from-backet"></i> <span>Logout</span></a>
            </div>

        </aside>


    <!--Main Content -->
    <main class="main-content">

        <header class="top-header">
            <h1>Niche Reviews</h1>
        </header>

        <!--Search and Filter Section-->
        <%# search bar and sort options for posts (not wired up yet) %>
        <section class="feed-controls card">
            <form action="/posts" method="GET" class="search-form">
                <input 
                    type="text"
                    name="search"
                    class="search-input"
                    placeholder="Search users or cafes..."
                >

                <select name="filter" class="filter-select">
                    <option value="newest">Newest</option>
                    <option value="most-liked">Most Liked</option>
                    <option value="highest-rated">Highest Rated</option>
                </select>

                <button type="submit" class="search-button">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Search
                </button>

            </form>

        </section>

        <!--Post feed-->
        <%# sample posts for now, will come from the database later %>
        <section class="feed">
            <!-- Post 1 -->
            <article class="cafe-card card">

                <div class="post-header">

                    <img
                        src="https://placehold.co/100x100?text=User"
                        alt="Profile picture"
                        class="profile-image"
                    >

                    <div class="post-user-info">
                        <h3>jessa.coffee</h3>
                        <p>Reviewed Lift Coffee · 2 hours ago</p>
                    </div>

                </div>

                <a href="/posts/1" class="post-image-link">

                    <img
                        src="https://placehold.co/900x500?text=Lift+Coffee"
                        alt="Coffee and pastry at Lift Coffee"
                        class="cafe-image"
                    >

                </a>

                <div class="cafe-details">

                    <h2>Lift Coffee</h2>

                    <div class="rating-row">
                        <span class="stars">★★★★☆</span>
                        <span class="rating-text">4 out of 5</span>
                    </div>

                    <p class="post-caption">
                        The coffee was really good and there was plenty of
                        seating. It was a little crowded, but I would
                        definitely come back to study here.
                    </p>

                    <div class="post-stats">

                        <span>
                            <i class="fa-regular fa-heart"></i>
                            24 likes
                        </span>

                        <span>
                            <i class="fa-regular fa-comment"></i>
                            6 comments
                        </span>

                    </div>

                    <a href="/posts/1" class="view-post-link">
                        View full post
                    </a>

                </div>

            </article>

            <!-- Post 2 -->
            <article class="cafe-card card">

                <div class="post-header">

                    <img
                        src="https://placehold.co/100x100?text=User"
                        alt="Profile picture"
                        class="profile-image"
                    >

                    <div class="post-user-info">
                        <h3>larryexplores</h3>
                        <p>Reviewed Stray Dog Coffee · 5 hours ago</p>
                    </div>

                </div>

                <a href="/posts/2" class="post-image-link">

                    <img
                        src="https://placehold.co/900x500?text=Stray+Dog+Coffee"
                        alt="Interior of Stray Dog Coffee"
                        class="cafe-image"
                    >

                </a>

                <div class="cafe-details">

                    <h2>Stray Dog Coffee</h2>

                    <div class="rating-row">
                        <span class="stars">★★★★★</span>
                        <span class="rating-text">5 out of 5</span>
                    </div>

                    <p class="post-caption">
                        Great atmosphere, friendly staff, and one of the best
                        iced lattes I have had recently.
                    </p>

                    <div class="post-stats">

                        <span>
                            <i class="fa-regular fa-heart"></i>
                            41 likes
                        </span>

                        <span>
                            <i class="fa-regular fa-comment"></i>
                            12 comments
                        </span>

                    </div>

                    <a href="/posts/2" class="view-post-link">
                        View full post
                    </a>

                </div>

            </article>

        </section>
        
    </main>
    </body>
</html>