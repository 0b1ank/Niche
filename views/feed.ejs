<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Community Feed</title>

        <link rel="stylesheet" href="/style.css">
        <link rel="stylesheet" href="/feedStyle.css">

        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    </head>
    <body>

        <!--Sidebar-->
        <%# nav links for the community feed section %>
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Niche</h2>
            </div>

            <ul class="nav-links">
                <li><a href="/"><i class="fa-solid fa-mug-hot"></i> <span>Cafes</span></a></li>
                <li><a href="/posts" class="active"><i class="fa-solid fa-images"></i> <span>Community</span></a></li>
                <li><a href="/create-post"><i class="fa-solid fa-plus"></i> <span>Create</span></a></li>
                <li><a href="/profile"><i class="fa-solid fa-user"></i> <span>Profile</span></a></li>
            </ul>

            <div class="sidebar-footer">
                <a href="/logout"><i class="fa-solid fa-right-from-backet"></i> <span>Logout</span></a>
            </div>

        </aside>


    <!--Main Content -->
    <main class="main-content">

        <header class="top-header">
            <h1>Niche Reviews</h1>
        </header>

        <!--Search and Filter Section-->
        <%# search bar and sort options for posts (not wired up yet) %>
        <section class="feed-controls card">
            <form action="/posts" method="GET" class="search-form">
                <input 
                    type="text"
                    name="search"
                    class="search-input"
                    placeholder="Search users or cafes..."
                >

                <select name="filter" class="filter-select">
                    <option value="newest">Newest</option>
                    <option value="most-liked">Most Liked</option>
                    <option value="highest-rated">Highest Rated</option>
                </select>

                <button type="submit" class="search-button">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Search
                </button>

            </form>

        </section>

        <!--Post feed-->
        <%# sample posts for now, will come from the database later %>
        <section class="feed">
            <% if(!posts || posts.length === 0) { %>
                <div class="card">
                    <p>No reviews have been posted yet.</p>
                </div>
            <% } else { %>

                <% posts.forEach((post) => { %>
                    <article class="cafe-card card">
                        <div class="post-header">
                            <img
                                src="<%= post.pfp || 'https://placehold.co/100x100?text=User' %>"
                                alt="<%= post.uname %>'s profile picture"
                                class="profile-image"
                            >

                            <div class="post-user-info">
                                <h3><%= post.uname %></h3>
                                <p>Reviewed <%= post.cname %></p>
                            </div>

                        </div>
                        <a href="/posts/<%= post.pid %>" class="post-image-link">
                            <img
                                src="<%= post.image || 'https://placehold.co/900x500?text=Cafe+Review' %>"
                                alt="Review photo for <%= post.cname %>"
                                class="cafe-image"
                            >
                        </a>

                        <div class="cafe-details">
                            <h2><%= post.cname %></h2>
                            
                            <div class="rating-row">
                                <span class="stars">
                                    <%= "★".repeat(post.rating) %> <%= "☆".repeat(5 - post.rating) %>
                                </span>

                                <span class="rating-text">
                                    <%= post.rating %> out of 5
                                </span>
                            </div>

                            <p class="post-caption">
                                <%= post.description %>
                            </p>

                            <a href="/posts/<%= post.pid %>" class="view-post-link">
                                View full post
                            </a>
                        </div>
                    </article>
                <% }) %>
            <% } %>
        </section>
    </main>
    </body>
</html>