<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Sidebar Template</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>Niche</h2>
            <% if (typeof user !== "undefined" && user) { %>
                <p>Hi, <%= user.uname %></p>
            <% } %>
        </div>
        <ul class="nav-links">
            <li><a href="/" class="active"><i class='bx bx-grid-alt'></i> <span>Home</span></a></li>
            <% if (user && user.urole === "owner") { %>
            <li><a href="/cafes/new"><i class='bx bx-plus'></i> <span>Create Cafe</span></a></li>
            <% } %>
            <li><a href="#"><i class='bx bx-chat'></i> <span>Profile</span></a></li>
            <li><a href="#"><i class='bx bx-cog'></i> <span>Feed</span></a></li>
        </ul>
        <div class="sidebar-footer">
            <a href="/logout"><i class='bx bx-log-out'></i> <span>Logout</span></a>
        </div>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <h1>Niche</h1>
        </header>
        <section class="content-body">
            <h2>Cafes</h2>

            <%# If the query returned no rows, show a friendly empty state %>
            <% if (!cafes || cafes.length === 0) { %>
                <div class="card">
                    <p>No cafes yet. Owners can add one with Create Cafe.</p>
                </div>
            <% } else { %>
                <%# cafes is the array passed from res.render in server.js %>
                <% cafes.forEach(function (cafe) { %>
                    <div class="card">
                        <h3><%= cafe.cname %></h3>
                        <% if (cafe.ccity) { %>
                            <p><%= cafe.ccity %></p>
                        <% } %>
                        <% if (cafe.cdescription) { %>
                            <p><%= cafe.cdescription %></p>
                        <% } %>
                        <%# cafe_img is a path like /uploads/.... that express.static can serve %>
                        <% if (cafe.cafe_img) { %>
                            <img src="<%= cafe.cafe_img %>" alt="<%= cafe.cname %>" width="200">
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </section>
    </main>

</body>
</html>