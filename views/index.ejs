<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Niche Cafes</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-header">
        </div>
        <ul class="nav-links">
            <li><a href="/" class="active"><i class='bx bx-home-alt-2'></i> <span>Home</span></a></li>
            <% if (user && user.urole === 'owner') { %>
            <%# only owners see the add cafe link %>
            <li><a href="/cafes/new"><i class="bx bx-book-add"></i> <span>Add Cafe</span></a></li>
            <% } %>
        </ul>

        <div class="sidebar-footer">
            <% if (user) { %>
            <a href="/logout">
                <i class='bx bx-log-out-circle'></i>
                <span>Log Out (<%= user.uname %>)</span>
            </a>
            <% } else { %>
            <a href="/login">
                <i class='bx bx-user-circle'></i>
                <span>Log In</span>
            </a>
            <% } %>
        </div>
    </aside>

    <main class="main-content">
        <div class="landing">
            <header class="top-header">
                <h1>Niche Cafes</h1>
            </header>

            <div class="controls">
                <%# city dropdown is built from whatever cities are in the cafe list %>
                <label for="city">City:</label>
                <select id="city">
                    <option value="all">All cities</option>
                    <% 
                      const citySet = [...new Set((cafes || []).map(c => c.ccity).filter(Boolean))].sort();
                      citySet.forEach(function(city) { 
                    %>
                      <option value="<%= city %>"><%= city %></option>
                    <% }) %>
                </select>

                <button id="fetchBtn">Search</button>
            </div> 
        </div>

        <div class="alert-banner"><h3>Recommended Cafes</h3></div>
        <div id="cafesContainer"></div>
    </main>

    <script>
        // fallback image if a cafe has no photo
        const DEFAULT_IMG = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=400';

        // all cafes loaded from the server, used for filtering by city
        const ALL_CAFES = <%- JSON.stringify(
          (cafes || []).map(function (cafe) {
            return {
              id: cafe.cid,
              title: cafe.cname || 'Untitled cafe',
              city: cafe.ccity || 'Unknown',
              abstract: cafe.cdescription || '',
              imageUrl: cafe.cafe_img || null,
            };
          })
        ) -%>;

        // stop user text from breaking the html
        function escapeHtml(text) {
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        // build and show cafe cards on the page
        function renderCafes(cafesToDisplay) {
            const container = document.getElementById('cafesContainer');
            container.innerHTML = '';

            if (cafesToDisplay.length === 0) {
                container.innerHTML = '<p style="color: #666; padding: 20px;">No cafes found matching those criteria. Try another city!</p>';
                return;
            }

            cafesToDisplay.forEach((cafe) => {
                const cafeDiv = document.createElement('div');
                cafeDiv.className = 'card cafe-card';
                cafeDiv.style.marginBottom = '20px';

                const imageUrl = cafe.imageUrl || DEFAULT_IMG;

                cafeDiv.innerHTML = `
                    <h3>${escapeHtml(cafe.title)}</h3>
                    <p style="font-size: 0.85rem; color: #777; margin-bottom: 8px;">
                        <strong>Location:</strong> ${escapeHtml(cafe.city)}
                    </p>
                    <p style="margin-bottom: 12px;">${escapeHtml(cafe.abstract)}</p>
                    <img src="${escapeHtml(imageUrl)}" width="150" style="border-radius: 4px; object-fit: cover; height: 100px;" alt="${escapeHtml(cafe.title)}">
                `;

                container.appendChild(cafeDiv);
            });
        }

        // filter cafes by the city dropdown and re-render
        function handleSearch() {
            const selectedCity = document.getElementById('city').value;
            const filteredList = selectedCity === 'all'
                ? ALL_CAFES
                : ALL_CAFES.filter((cafe) => cafe.city === selectedCity);
            renderCafes(filteredList);
        }

        // show all cafes when the page first loads
        document.addEventListener('DOMContentLoaded', () => {
            renderCafes(ALL_CAFES);
        });

        document.getElementById('fetchBtn').addEventListener('click', handleSearch);
    </script>
</body>
</html>
