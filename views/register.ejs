<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Niche Cafes - Register</title>
    <link rel="stylesheet" href="login.css">
    <link rel="stylesheet" href="style.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-header"></div>
        <ul class="nav-links">
            <li><a href="/" class="active"><i class='bx bx-home-alt-2'></i> <span>Home</span></a></li>
            <li><a href="#"><i class="bx bx-book-add"></i> <span>Add</span></a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="login-header">
            <h2>Create a New Account</h2>
            <p>Please enter your information</p>
        </div>

        <%# register form, needs multipart so we can upload a profile pic %>
        <form action="/register" method="POST" enctype="multipart/form-data" id="newAccountForm">
            <div class="input-group">
                <label for="username">Username</label>
                <div class="input-wrapper">
                    <i class='bx bx-user'></i>
                    <input type="text" id="username" name="username" placeholder="Enter your username" required>
                </div>
            </div>

            <div class="input-group">
                <label for="email">Email</label>
                <div class="input-wrapper">
                    <i class='bx bx-envelope'></i>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required>
                </div>
            </div>

            <div class="input-group">
                <label for="password">Password</label>
                <div class="input-wrapper">
                    <i class='bx bx-lock-alt'></i>
                    <input type="password" id="password" name="password" placeholder="Enter your password" required>
                </div>
            </div>
            <br/>

            <!-- Main Action Control Container -->
            <div class="action-group">
                <%# hidden file input, the button below triggers it %>
                <input type="file" id="pfp" name="pfp" accept="image/*" style="display: none;">

                <div class="upload-row">
                    <button type="button" class="user-btn upload-btn" id="uploadTriggerBtn">
                        <i class="bx bx-upload"></i> 
                        <span>Upload Photo</span>
                    </button>

                    <div class="avatar-preview-circle" id="avatarPreview">
                        <i class='bx bx-user'></i>
                    </div>
                </div>

                <label>Account Type</label>

                <%# pick owner or user, stored in hidden input for the server %>
                <input type="hidden" name="role" id="roleInput" value="user">

                <div class="role-row">
                    <button type="button" class="user-btn role-btn role-btn-owner" id="ownerBtn">
                        <i class='bx bx-briefcase'></i>
                        <span>Owner</span>
                    </button>
                    <button type="button" class="user-btn role-btn role-btn-user active" id="userBtn">
                        <i class='bx bx-user'></i>
                        <span>User</span>
                    </button>
                </div>

                <button type="submit" class="submit-btn">Register</button>
            </div>
        </form>

        <br>
        <%# or register with google instead %>
        <div class="auth-links" style="text-align: center;">
            <p><a href="/auth/google">Continue with Google</a></p>
            <p><a href="/login">Already have an account? Log in</a></p>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // click the upload button to open the file picker
            const uploadTriggerBtn = document.getElementById('uploadTriggerBtn');
            const realFileInput = document.getElementById('pfp');
            const avatarPreview = document.getElementById('avatarPreview');

            uploadTriggerBtn.addEventListener('click', () => {
                realFileInput.click();
            });

            realFileInput.addEventListener('change', function() {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    // show a preview of the chosen photo before submitting
                    reader.onload = function(e) {
                        avatarPreview.innerHTML = `<img src="${e.target.result}" alt="User Profile Preview">`;
                    }
                    reader.readAsDataURL(file);
                }
            });

            // toggle between owner and user role buttons
            const userBtn = document.getElementById('userBtn');
            const ownerBtn = document.getElementById('ownerBtn');
            const roleInput = document.getElementById('roleInput');

            userBtn.addEventListener('click', (e) => {
                e.preventDefault();
                roleInput.value = 'user';
                userBtn.classList.add('active');
                ownerBtn.classList.remove('active');
            });

            ownerBtn.addEventListener('click', (e) => {
                e.preventDefault();
                roleInput.value = 'owner';
                ownerBtn.classList.add('active');
                userBtn.classList.remove('active');
            });
        });
    </script>
</body>
</html>
