<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.uname %>'s Profile - Niche Cafes</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/profile.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
        </div>
        <ul class="nav-links">
                <li><a href="/"><i class='bx bx-home-alt-2'></i> <span>Home</span></a></li>
                
                <li><a href="/create-post"><i class="bx bx-book-add"></i> <span>Add</span></a></li>
                <li><a href="/posts" ><i class='bx bx-list-ul'></i> <span>Community</span></a></li>
                
                <!-- <li><a href="/create-post"><i class="bx bx-book-add"></i> <span></span></a></li> -->
                <!-- <li><a href="#"><i class='bx bx-chat'></i> <span>Profile</span></a></li> -->
                <!-- <li><a href="#"><i class='bx bx-list-ul'></i><span></span></a></li> -->
            </ul>

            <div class="sidebar-footer">
                <% if (user) { %>
                <a href="/logout">
                    <i class='bx bx-log-out-circle'></i>
                    <span>Log Out (<%= user.uname %>)</span>
                </a>
                <% } else { %>
                <a href="/login">
                    <i class='bx bx-user-circle'></i>
                    <span>Log In</span>
                </a>
                <% } %>
            </div>
    </aside>

<main class="main-content">
    <div class="avatar-container">
        <!-- 1. Profile Picture / Avatar on the left -->
        <% if (user.pfp) { %>
            <img src="<%= user.pfp %>" alt="Profile Picture" class="profile-img">
        <% } else { %>
            <i class='bx bx-user-circle default-avatar'></i>
        <% } %>

        <!-- 2. Text Stack on the right -->
        <div class="user-info">
            <h2><%= user.uname %></h2>
            <p class="user-email">
                <i class='bx bx-envelope'></i> <%= user.uemail %>
            </p>
            <span class="role-badge <%= user.urole %>">
                <i class='bx <%= user.urole === "owner" ? "bx-store-alt" : "bx-user" %>'></i>
                <%= user.urole.toUpperCase() %>
            </span>
        </div>
    </div>

    <hr class="divider">

    <!-- Main Content Area (under profile header) -->
    <section class="profile-body">
        
        <!-- Shared Posts Section -->
        <h2 class="section-title">Shared Posts</h2>
        
        <div class="posts-grid">
            <% if (userPosts && userPosts.length > 0) { %>
                <% userPosts.forEach(function(post) { %>
                    <div class="post-card">
                        <img 
                            src="<%= post.imageUrl.startsWith('/') || post.imageUrl.startsWith('http') ? post.imageUrl : '/' + post.imageUrl %>" 
                            alt="<%= post.title %>" 
                            class="post-img"
                        >
                        <div class="post-info">
                            <h3><%= post.title %></h3>
                            <p class="post-city"><%= post.city %></p>
                            <p><%=post.rating %><i class="bx bx-star"></i></p>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="no-posts">No shared posts yet.</p>
            <% } %>
        </div>

    </section>
</main>



</body>
</html>