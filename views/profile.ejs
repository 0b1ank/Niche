<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.uname %>'s Profile - Niche Cafes</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
        </div>
        <ul class="nav-links">
            <li><a href="/" class="active"><i class='bx bx-home-alt-2'></i> <span></span></a></li>
            <li><a href="#"><i class="bx bx-book-add"></i> <span></span></a></li>
            <li><a href="#"><i class='bx bx-list-ul'></i><span></span></a></li>
        </ul>
    </aside>

<main class="main-content">
    <div class="avatar-container">
        <!-- 1. Profile Picture / Avatar on the left -->
        <% if (user.pfp) { %>
            <img src="<%= user.pfp %>" alt="Profile Picture" class="profile-img">
        <% } else { %>
            <i class='bx bx-user-circle default-avatar'></i>
        <% } %>

        <!-- 2. Text Stack on the right -->
        <div class="user-info">
            <h2><%= user.uname %></h2>
            <p class="user-email">
                <i class='bx bx-envelope'></i> <%= user.uemail %>
            </p>
            <span class="role-badge <%= user.urole %>">
                <i class='bx <%= user.urole === "owner" ? "bx-store-alt" : "bx-user" %>'></i>
                <%= user.urole.toUpperCase() %>
            </span>
        </div>
    </div>

    <hr class="divider">

    <div class="profile-actions">
        <% if (user.urole === "owner") { %>
            <a href="/cafes/new" class="btn primary-btn"><i class='bx bx-plus'></i> Add New Cafe</a>
        <% } %>
        <a href="/logout" class="btn danger-btn"><i class='bx bx-log-out'></i> Log Out</a>
    </div>
</main>
</body>
</html>