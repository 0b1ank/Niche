<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Finish signup — Niche</title>
</head>
<body>
  <%# last step after google login - pick username and account type %>
  <h1>Finish signing up</h1>
  <p>Signed in with Google as <strong><%= email %></strong></p>
  <p>Choose a username and whether you are a cafe owner.</p>

  <% if (error) { %>
    <p style="color: red;"><%= error %></p>
  <% } %>

  <form action="/auth/finish-signup" method="POST">
    <div>
      <label for="username">Username</label>
      <input type="text" id="username" name="username" value="<%= username %>" required>
    </div>
    <fieldset>
      <legend>Account type</legend>
      <label>
        <input type="radio" name="role" value="user" checked>
        User — browse, post, and review cafes
      </label>
      <br>
      <label>
        <input type="radio" name="role" value="owner">
        Owner — everything a user can do, plus create a cafe
      </label>
    </fieldset>
    <button type="submit">Create account</button>
  </form>
</body>
</html>
