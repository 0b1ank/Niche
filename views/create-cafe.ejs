<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Cafe — Niche</title>
</head>
<body>
  <%# form for owners to add a new cafe to the site %>
  <h1>Create a cafe</h1>
  <p>Signed in as <%= user.uname %> (owner)</p>
  <% if (typeof error !== "undefined" && error) { %>
    <p style="color: red;"><%= error %></p>
  <% } %>
  <form action="/cafes" method="POST" enctype="multipart/form-data">
    <div>
      <label for="cname">Cafe name</label>
      <input type="text" id="cname" name="cname" required>
    </div>
    <div>
      <label for="caddress">Address</label>
      <input type="text" id="caddress" name="caddress">
    </div>
    <div>
      <label for="ccity">City</label>
      <input type="text" id="ccity" name="ccity">
    </div>
    <div>
      <label for="czip">ZIP</label>
      <input type="text" id="czip" name="czip">
    </div>
    <div>
      <label for="cphonenum">Phone</label>
      <input type="text" id="cphonenum" name="cphonenum">
    </div>
    <div>
      <label for="cdescription">Description</label>
      <textarea id="cdescription" name="cdescription" rows="4"></textarea>
    </div>
    <div>
      <label for="cafe_img">Cafe image (optional)</label>
      <input type="file" id="cafe_img" name="cafe_img" accept="image/*">
    </div>
    <button type="submit">Create cafe</button>
  </form>
  <p><a href="/">Back home</a></p>
</body>
</html>
